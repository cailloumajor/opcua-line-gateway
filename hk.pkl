amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"

import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["actionlint"] = Builtins.actionlint
  ["betterleaks"] = Builtins.betterleaks
  ["cargo-clippy"] = Builtins.cargo_clippy
  ["cargo-fmt"] = Builtins.cargo_fmt
  ["editorconfig-checker"] = Builtins.editorconfig_checker
  ["ghalint"] = Builtins.ghalint_workflow
  ["json-config-schema"] {
    check_diff = "diff schema/config.schema.json <(cargo generate-config-schema)"
    shell = "bash -o errexit -c"
  }
  ["mise"] = Builtins.mise
  ["pinact"] = Builtins.pinact
  ["pkl"] = Builtins.pkl
  ["pkl-format"] = Builtins.pkl_format
  ["rumdl"] = Builtins.rumdl
  ["tombi"] = Builtins.tombi
  ["typos"] = Builtins.typos
  ["zizmor"] = Builtins.zizmor
}

env {
  ["CARGO_BUILD_WARNINGS"] = "deny"
}

exclude = "CHANGELOG.md"

hooks {
  ["commit-msg"] {
    steps {
      ["check-conventional-commit"] = Builtins.check_conventional_commit
    }
  }
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
